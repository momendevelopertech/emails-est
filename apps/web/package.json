{
  "name": "@sphinx/web",
  "version": "1.0.0",
  "private": true,
  "description": "Messaging-only Next.js frontend",
  "scripts": {
    "clean:next": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "npm run clean:next && next dev -p 3000",
    "build": "npm run clean:next && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "next lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.28.6",
    "axios": "^1.6.7",
    "lucide-react": "^0.356.0",
    "next": "^14.2.35",
    "next-intl": "^3.12.0",
    "next-pwa": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "14.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2"
  }
