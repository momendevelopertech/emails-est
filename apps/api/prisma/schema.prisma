generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  BRANCH_SECRETARY
  SUPPORT
  EMPLOYEE
}

enum TokenType {
  REFRESH
  RESET
}

enum RecipientStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum RecipientSheet {
  LEGACY
  EST1
  EST2
  SPARE
  BLACKLIST
}

enum TemplateType {
  EMAIL
  WHATSAPP
  BOTH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  fullName     String
  passwordHash String
  role         Role     @default(EMPLOYEE)
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  tokenType TokenType @default(REFRESH)
  expiresAt DateTime
  isRevoked Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked])
}

model Template {
  id                             String       @id @default(cuid())
  name                           String       @unique
  type                           TemplateType @default(BOTH)
  subject                        String
  body                           String
  include_confirmation_button    Boolean      @default(false)
  created_at                     DateTime     @default(now())
}

model RecipientCycle {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  source_file_name String?
  imported_count   Int         @default(0)
  skipped_count    Int         @default(0)
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  recipients       Recipient[]

  @@index([created_at])
}

model Recipient {
  id              String          @id @default(cuid())
  cycleId         String?
  name            String
  division        String?
  arabic_name     String?
  email           String?
  phone           String?
  employer        String?
  kind_of_school  String?
  title           String?
  insurance_number String?
  institution_tax_number String?
  national_id_number String?
  national_id_picture String?
  personal_photo  String?
  preferred_proctoring_city String?
  preferred_test_center String?
  bank_account_name String?
  bank_name       String?
  bank_branch_name String?
  account_number  String?
  iban_number     String?
  exam_type       String?
  role            String?
  day             String?
  date            String?
  test_center     String?
  faculty         String?
  room            String?
  room_est1       String?
  type            String?
  governorate     String?
  address         String?
  building        String?
  location        String?
  map_link        String?
  bank_divid      String?
  additional_info_1 String?
  additional_info_2 String?
  arrival_time    String?
  confirmation_token String?      @unique
  confirmed_at    DateTime?
  declined_at     DateTime?
  sheet           RecipientSheet  @default(LEGACY)
  status          RecipientStatus @default(PENDING)
  error_message   String?
  attempts_count  Int             @default(0)
  last_attempt_at DateTime?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  cycle           RecipientCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  logs            Log[]

  @@index([cycleId, created_at])
  @@index([cycleId, status])
  @@index([cycleId, sheet])
}

model Log {
  id          String          @id @default(cuid())
  recipientId String
  status      RecipientStatus
  error       String?
  created_at  DateTime        @default(now())

  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
}

model EmailSettings {
  id                     String              @id @default("default")
  sender_name            String
  sender_email           String
  mail_from              String
  active_sender_account_id String?
  updated_at             DateTime            @updatedAt
  active_sender_account  SenderEmailAccount? @relation(fields: [active_sender_account_id], references: [id], onDelete: SetNull)

  @@map("email_settings")
}

model WhatsAppSettings {
  id                 String   @id @default("default")
  api_url            String
  media_url          String
  id_instance        String
  api_token_instance String
  updated_at         DateTime @updatedAt

  @@map("whatsapp_settings")
}

model SenderEmailAccount {
  id               String          @id @default(cuid())
  label            String
  sender_name      String
  sender_email     String
  mail_from        String
  smtp_host        String
  smtp_port        Int             @default(587)
  smtp_secure      Boolean         @default(false)
  smtp_require_tls Boolean         @default(true)
  smtp_username    String
  smtp_password    String
  smtp_daily_limit Int?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  active_in_settings EmailSettings[]

  @@map("sender_email_accounts")
}
